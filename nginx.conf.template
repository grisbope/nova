server {
  listen 80;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  # Docker embedded DNS resolves swarm/overlay service names; public DNS as fallback.
  resolver 127.0.0.11 ipv6=off valid=10s;

  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;
  add_header Permissions-Policy "microphone=(self), camera=()" always;

  # Reverse proxy to OpenClaw — server-side, bearer injected here, no CORS in browser.
  # OpenAI Speech-to-Text proxy. Browser does Web Speech API fallback via MediaRecorder
  # because Chromium WebView on LineageOS-without-GApps has no working webkitSpeechRecognition.
  location /stt/ {
    rewrite ^/stt/.*$ /v1/audio/transcriptions break;
    proxy_pass https://api.openai.com;
    proxy_ssl_server_name on;
    proxy_ssl_name api.openai.com;
    proxy_set_header Host api.openai.com;
    proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";
    proxy_set_header xi-api-key "";
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_request_buffering off;
    proxy_buffering off;
    proxy_cache off;
    client_max_body_size 25m;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;
  }

  # OpenAI TTS proxy - same-origin, API key injected server-side.
  location /tts/ {
    rewrite ^/tts/.*$ /v1/audio/speech break;
    proxy_pass https://api.openai.com;
    proxy_ssl_server_name on;
    proxy_ssl_name api.openai.com;
    proxy_set_header Host api.openai.com;
    proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";
    proxy_set_header xi-api-key "";
    proxy_set_header Accept "audio/mpeg";
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 60s;
    proxy_send_timeout 60s;
  }

  location /openclaw/ {
    set $oc "http://openclaw:18789";
    rewrite ^/openclaw/(.*)$ /$1 break;
    proxy_pass $oc;
    proxy_ssl_server_name on;
    proxy_ssl_name openclaw.grisbope.com;
    proxy_set_header Host openclaw.grisbope.com;
    proxy_set_header Authorization "Bearer ${OPENCLAW_KEY}";
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    chunked_transfer_encoding on;
  }

  location /assets/ {
    expires 1y;
    add_header Cache-Control "public, immutable";
    try_files $uri =404;
  }

  location / {
    add_header Cache-Control "no-cache" always;
    try_files $uri $uri/ /index.html;
  }
}
