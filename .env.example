# OpenClaw gateway — leave blank/relative when serving behind the bundled nginx
# reverse proxy (Dockerfile + nginx.conf.template handle auth server-side).
# Only set this when running `npm run dev` directly without the proxy.
VITE_OPENCLAW_URL=/openclaw
VITE_OPENCLAW_KEY=
VITE_OPENCLAW_MODEL=openclaw/main
# Optional: force a specific LLM per request via header (e.g. medicina)
# VITE_OPENCLAW_MODEL_OVERRIDE=openrouter/google/gemini-2.5-flash

# Voice
VITE_WAKE_WORDS=nova,alexa,daye,jarvis
VITE_END_WORDS=adiós,adios,gracias nova,gracias alexa,gracias daye,gracias jarvis,hasta luego,chao
VITE_LANG=es-ES
VITE_SILENCE_MS=900
VITE_POST_WAKE_MS=7000
VITE_VAD_RMS_OPEN=0.01
VITE_VAD_RMS_CLOSE=0.0045
VITE_VAD_OPEN_FRAMES=2

# Login
VITE_LOGIN_PIN=123456
VITE_AUTH_SECRET=change-me-to-a-random-string-just-for-extra-mixing

# OpenAI audio
VITE_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
VITE_OPENAI_TTS_MODEL=gpt-4o-mini-tts
VITE_OPENAI_TTS_VOICE=echo
VITE_OPENAI_TTS_FORMAT=mp3
VITE_OPENAI_TTS_SPEED=1.08
VITE_OPENAI_TTS_INSTRUCTIONS=Habla en espanol latino, natural, claro, cercano y con ritmo conversacional, ligeramente agil sin sonar apresurado.

# System prompt
VITE_SYSTEM_PROMPT=Eres Nex, asistente por voz. Responde corto, natural, conversacional, sin emojis, sin markdown, sin listas, sin asteriscos, sin caracteres especiales. Solo texto plano hablado. Máximo 2-3 frases salvo que se pida más.
